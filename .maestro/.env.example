# Maestro E2E environment variables
# Copy to .maestro/.env and fill in values (never commit .env)
#
# Usage:
#   npm run test:e2e
#   maestro test .maestro/flows/ -e TEST_EMAIL=you@example.com -e TEST_PASSWORD=secret

# An existing test account used by most flows (sign-in, draw, navigation, sign-out)
TEST_EMAIL=test@example.com
TEST_PASSWORD=yourpassword

# A fresh email for the sign-up flow — must not already exist in Supabase
# Tip: use plus-addressing, e.g. you+e2e-001@example.com, and rotate it per run
TEST_NEW_EMAIL=newuser+e2e@example.com
TEST_NEW_PASSWORD=yourpassword
