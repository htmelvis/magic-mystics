{
  "expo": {
    "name": "Magic Mystics",
    "slug": "-magic-mystics",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-draft.png",
    "userInterfaceStyle": "dark",
    "scheme": "magic-mystics",
    "splash": {
      "image": "./assets/mm-splash-draft.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.edwardwieczorek.magicmystics",
      "associatedDomains": ["applinks:links.magicmystics.com"]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-draft.png",
        "backgroundColor": "#000000"
      },
      "package": "com.edwardwieczorek.magicmystics",
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "links.magicmystics.com",
              "pathPrefix": "/reading/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router", "@react-native-community/datetimepicker", "expo-localization"],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "115cd32c-a763-4b37-a85d-c77e3680e2d0"
      }
    },
    "owner": "htmelvis"
  }
}
